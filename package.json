{
  "name": "monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build:dbl": "cd apps/dev-blog && bun run build",
    "start:dbl": "cd apps/dev-blog && bun run start",
    "dev:dbl": "cd apps/dev-blog && bun run dev",
    "build:di": "cd apps/discovery-instance && bun run build",
    "start:di": "cd apps/discovery-instance && bun run start",
    "dev:di": "cd apps/discovery-instance && bun run dev",
    "build:uc": "cd apps/under-construction && bun run build",
    "start:uc": "cd apps/under-construction && bun run start",
    "dev:uc": "cd apps/under-construction && bun run dev",
    "check:ts": "tsc --noEmit",
    "check:format": "biome check .",
    "check:lint": "oxlint",
    "check:all": "bun run check:ts && bun run check:format && bun run check:lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.5.3",
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.9",
    "oxlint": "^0.15.0",
    "typescript": "^5.0.0"
  }
}
